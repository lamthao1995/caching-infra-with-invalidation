# ─── MySQL ────────────────────────────────────────────────────────
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=app
MYSQL_PASSWORD=app
MYSQL_DATABASE=catalog
MYSQL_ROOT_PASSWORD=root
MYSQL_HOST_PORT=3306

# ─── Redis ────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_HOST_PORT=6379
# Default cache TTL for cache-aside reads (Spring Duration, e.g. 10m, 30s)
CACHE_TTL=10m

# ─── Writer service ───────────────────────────────────────────────
WRITER_PORT=8080
WRITER_HOST_PORT=8080

# ─── Reader service ───────────────────────────────────────────────
READER_PORT=8081
READER_HOST_PORT=8081

# ─── Kafka (Debezium publishes here, invalidator consumes) ───────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
# Topic created by the Debezium connector: <topic.prefix>.<db>.<table>
KAFKA_TOPIC=cdc.catalog.items
KAFKA_GROUP=cache-invalidator
# Listener threads spawned per replica (must be <= partitions on the topic, default 6)
KAFKA_CONCURRENCY=3

# ─── Invalidator (Kafka consumer) ─────────────────────────────────
INVALIDATOR_MGMT_PORT=8090
INVALIDATOR_MGMT_HOST_PORT=8090

# ─── Stress generator (used by `make compose-stress`) ─────────────
STRESS_RPS=2000
STRESS_DURATION=60s
STRESS_WORKERS=32
STRESS_KEYSPACE=10000
STRESS_READ_RATIO=0.8
STRESS_UPDATE_RATIO=0.1
